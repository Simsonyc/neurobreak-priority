generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DiagnosticSessionStatus {
  created
  in_progress
  ready_to_finalize
  finalizing
  completed
  error
}

enum ProfileSelected {
  entrepreneur
  salarie
  independant
  createur
}

model DiagnosticSession {
  id                  String                  @id @default(cuid())
  firstName           String                  @map("first_name")
  email               String
  profilSelected      ProfileSelected         @map("profil_selected")
  status              DiagnosticSessionStatus @default(created)
  messages            Json                    @default("[]")
  lastDiagnosticState Json?                   @map("last_diagnostic_state")
  resultId            String?                 @unique @map("result_id")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")

  result DiagnosticResult?

  @@map("diagnostic_sessions")
}

model DiagnosticResult {
  id             String          @id @default(cuid())
  sessionId      String          @unique @map("session_id")
  firstName      String          @map("first_name")
  email          String
  profilSelected ProfileSelected @map("profil_selected")
  diagnosticJson Json            @map("diagnostic_json")
  createdAt      DateTime        @default(now()) @map("created_at")

  session          DiagnosticSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  engineOutput     PriorityEngineOutput?
  moduleSelections ModuleSelection[]
  appSession       AppSession?

  @@map("diagnostic_results")
}

model PriorityEngineOutput {
  id         String   @id @default(cuid())
  resultId   String   @unique
  engineJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  result           DiagnosticResult  @relation(fields: [resultId], references: [id])
  moduleSelections ModuleSelection[]
}

model ModuleSelection {
  id                String   @id @default(cuid())
  resultId          String
  engineOutputId    String
  moduleName        String
  selectedOption    Json
  regenerationCount Int      @default(0)
  status            String   @default("in_progress")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  result       DiagnosticResult     @relation(fields: [resultId], references: [id])
  engineOutput PriorityEngineOutput @relation(fields: [engineOutputId], references: [id])

  @@unique([resultId, moduleName])
}

model AppSession {
  id        String   @id @default(cuid())
  resultId  String   @unique
  progress  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  result DiagnosticResult @relation(fields: [resultId], references: [id])
}
